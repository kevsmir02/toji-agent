{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/hooks/session-start.sh",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/pre-tool-security.sh",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "./scripts/hooks/post-edit-validate.sh",
        "timeout": 30
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/hooks/session-stop.sh",
        "timeout": 5
      }
    ]
  }
}
